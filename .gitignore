# --------------------------------------------------------------------------- #
# Python                                                                       #
# --------------------------------------------------------------------------- #
__pycache__/
*.py[cod]

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
.python-version

# Test / coverage / type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
test-results*.xml

# --------------------------------------------------------------------------- #
# HDL IP Packager runtime state (do not commit caches or resolved artifacts)   #
# --------------------------------------------------------------------------- #
# Local on-disk cache / catalog the packager populates when resolving cores.
.hdlpkg/
.hdlpkg-cache/
# Generated tool/back-end output (EDAM, project files, build trees).
gen/
work/
*.ipkg
# Generated CycloneDX SBOMs (hdlpkg pack --sbom default output).
*.cdx.json
# Generated XML at the repo root: IP-XACT exports (export-ipxact) and CI reports
# (coverage.xml / test-results.xml). No source XML lives at the root.
/*.xml

# MkDocs build output (the docs site is published by CI, never committed).
site/

# --------------------------------------------------------------------------- #
# Editor / OS                                                                  #
# --------------------------------------------------------------------------- #
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Temporary / log files
*.bak
*.tmp
*.log

# --------------------------------------------------------------------------- #
# Local-only work (kept out of the repo on purpose)                            #
# --------------------------------------------------------------------------- #
# Customer/marketing material (deck builder, .pptx, slide previews).
marketing/
# Scratch directories for ad-hoc experiments.
.scratch*/
# Per-user agent settings (the shared .claude/ files stay tracked).
.claude/settings.local.json
